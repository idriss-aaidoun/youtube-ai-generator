# ============================================================
# AI Video Generator — Configuration
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# ── LLM (Ollama) ─────────────────────────────────────────────
# Modèle à utiliser : mistral (défaut), llama3, gemma3, phi3
LLM_MODEL=mistral

# ── Images — Option 1 : Pexels API (gratuit) ─────────────────
# Inscription gratuite sur : https://www.pexels.com/api/
# Sans cette clé, des images générées par Pillow sont utilisées
PEXELS_API_KEY=

# ── Images — Option 2 : Stable Diffusion (GPU requis) ────────
# Décommenter le service stable-diffusion dans docker-compose.yml
# puis renseigner l'URL ici :
SD_WEBUI_URL=

# ── Exemples de configuration avancée ────────────────────────
# LLM_MODEL=llama3        # Plus puissant (nécessite plus de RAM)
# LLM_MODEL=gemma3        # Plus léger
